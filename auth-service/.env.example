# Add these in Vercel Dashboard → Project → Settings → Environment Variables
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/flowpay_auth?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_32_char_minimum_key
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
NODE_ENV=production
CORS_ORIGIN=https://your-ui.vercel.app
