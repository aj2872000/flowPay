{
  "name": "billing-service",
  "version": "1.0.0",
  "description": "FlowPay Billing Service – subscriptions, plans, payments, retries, invoices",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev":   "nodemon src/index.js",
    "test":  "jest --forceExit --detectOpenHandles"
  },
  "jest": {
    "testEnvironment":          "node",
    "setupFilesAfterFramework": ["./src/tests/setup.js"],
    "testMatch":                ["**/tests/**/*.test.js"],
    "testTimeout":              30000
  },
  "dependencies": {
    "express":           "^4.18.2",
    "mongoose":          "^8.1.1",
    "dotenv":            "^16.3.1",
    "helmet":            "^7.1.0",
    "cors":              "^2.8.5",
    "morgan":            "^1.10.0",
    "express-validator": "^7.0.1",
    "winston":           "^3.11.0",
    "uuid":              "^9.0.0",
    "axios":             "^1.6.5",
    "node-cron":         "^3.0.3"
  },
  "devDependencies": {
    "nodemon":               "^3.0.2",
    "jest":                  "^29.7.0",
    "supertest":             "^6.3.3",
    "mongodb-memory-server": "^9.1.6"
  }
}
